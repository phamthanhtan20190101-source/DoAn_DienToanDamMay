
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let lastScrollTop = 0;
        const topBar = document.querySelector('header.top-bar');
        window.addEventListener('scroll', function () {
            let scrollTop = window.pageYOffset || document.documentElement.scrollTop;
            if (scrollTop > lastScrollTop && scrollTop > 100) { topBar.classList.add('top-bar-hidden'); }
            else { topBar.classList.remove('top-bar-hidden'); }
            lastScrollTop = scrollTop <= 0 ? 0 : scrollTop;
        }, false);
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const sidebarToggle = document.getElementById('sidebarToggle');
            const body = document.body;

            if (sidebarToggle) {
                // Kiểm tra trạng thái đã lưu
                if (localStorage.getItem('sidebar-state') === 'hidden') {
                    body.classList.add('sidebar-hidden');
                    sidebarToggle.querySelector('i').className = 'bi bi-layout-sidebar-inset';
                }

                // Xử lý khi bấm nút
                sidebarToggle.addEventListener('click', () => {
                    body.classList.toggle('sidebar-hidden');

                    const icon = sidebarToggle.querySelector('i');
                    if (body.classList.contains('sidebar-hidden')) {
                        icon.className = 'bi bi-layout-sidebar-inset';
                        localStorage.setItem('sidebar-state', 'hidden');
                    } else {
                        icon.className = 'bi bi-list';
                        localStorage.setItem('sidebar-state', 'visible');
                    }
                });
            }
        });
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const containers = document.querySelectorAll('.scrolling-container');

            containers.forEach(container => {
                const wrapper = container.querySelector('.scrolling-wrapper');
                const btnLeft = container.querySelector('.btn-left');
                const btnRight = container.querySelector('.btn-right');

                // 1. Chức năng BẤM NÚT (Click)
                btnLeft.addEventListener('click', () => {
                    wrapper.scrollBy({ left: -350, behavior: 'smooth' }); // Lướt lùi 350px
                });
                btnRight.addEventListener('click', () => {
                    wrapper.scrollBy({ left: 350, behavior: 'smooth' }); // Lướt tới 350px
                });

                // 2. Chức năng KÉO THẢ (Drag)
                let isDown = false;
                let startX, scrollLeft;

                wrapper.style.cursor = 'grab';
                wrapper.addEventListener('mousedown', (e) => {
                    isDown = true;
                    wrapper.style.cursor = 'grabbing';
                    startX = e.pageX - wrapper.offsetLeft;
                    scrollLeft = wrapper.scrollLeft;
                });
                wrapper.addEventListener('mouseleave', () => { isDown = false; wrapper.style.cursor = 'grab'; });
                wrapper.addEventListener('mouseup', () => { isDown = false; wrapper.style.cursor = 'grab'; });
                wrapper.addEventListener('mousemove', (e) => {
                    if (!isDown) return;
                    e.preventDefault();
                    const x = e.pageX - wrapper.offsetLeft;
                    const walk = (x - startX) * 2;
                    wrapper.scrollLeft = scrollLeft - walk;
                });
            });
        });
    </script>
    
    <% if (typeof topBaiViet !== 'undefined' && topBaiViet.length > 0) { %>
    <script>
        // Sử dụng JSON.parse để VS Code không báo lỗi cú pháp
        const topTitles = JSON.parse('<%- JSON.stringify(topBaiViet.map(b => b.TieuDe)) %>');
        const topViews = JSON.parse('<%- JSON.stringify(topBaiViet.map(b => b.LuotXem || 0)) %>');

        const ctx = document.getElementById('trendingChart').getContext('2d');
        const gradient = ctx.createLinearGradient(0, 0, 0, 300);
        gradient.addColorStop(0, 'rgba(67, 90, 36, 0.3)'); 
        gradient.addColorStop(1, 'rgba(255, 255, 255, 0)');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: topTitles.map(t => t.length > 15 ? t.substring(0, 15) + '..' : t),
                datasets: [{
                    label: 'Lượt xem',
                    data: topViews,
                    borderColor: '#435a24',
                    backgroundColor: gradient,
                    fill: true,
                    borderWidth: 3,
                    tension: 0.4,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: '#435a24',
                    pointRadius: 5,
                    pointHoverRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        display: false
                    },
                    x: {
                        grid: { display: false },
                        ticks: {
                            color: '#435a24',
                            font: { size: 11, weight: '600' }
                        }
                    }
                }
            }
        });
    </script>
<% } %>
<!--chatbot -->
<div id="chat-wrapper">
    <button id="chat-button" class="btn shadow-lg">
        <i class="bi bi-robot"></i>
    </button>

    <div id="chat-window" class="d-none">
        <div class="chat-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-stars"></i> Trạm Trưởng AI</span>
            <button type="button" class="btn-close btn-close-white" id="close-chat"></button>
        </div>
        <div id="chat-content" class="p-3">
            <div class="bot-msg">Chào Vy! Mình là Trạm Trưởng. Bạn cần mình giúp gì về Văn học không?</div>
        </div>
        <div class="chat-input-area p-2 border-top">
            <div class="input-group">
                <input type="text" id="user-input" class="form-control border-0" placeholder="Hỏi gì đó...">
                <button class="btn btn-success" id="send-btn"><i class="bi bi-send"></i></button>
            </div>
        </div>
    </div>
</div>

<style>
    #chat-wrapper { position: fixed; bottom: 30px; right: 30px; z-index: 1000; }
    #chat-button { 
        width: 60px; height: 60px; border-radius: 50%; 
        background: var(--primary-color); color: white; 
        font-size: 1.8rem; display: flex; align-items: center; justify-content: center;
        transition: transform 0.3s ease;
    }
    #chat-button:hover { transform: scale(1.1); color: white; }
    
    #chat-window { 
        width: 350px; height: 450px; background: white; 
        border-radius: 15px; overflow: hidden; display: flex; 
        flex-direction: column; box-shadow: 0 10px 30px rgba(0,0,0,0.2); 
    }
    .chat-header { background: var(--primary-color); color: white; padding: 12px 15px; font-weight: bold; }
    #chat-content { 
        flex-grow: 1; overflow-y: auto; background: #f8f9fa; 
        display: flex; flex-direction: column; gap: 10px; 
    }
    .bot-msg, .user-msg { padding: 8px 12px; border-radius: 12px; max-width: 85%; font-size: 0.9rem; line-height: 1.4; }
    .bot-msg { background: #eef7e8; align-self: flex-start; border-bottom-left-radius: 2px; color: #333; }
    .user-msg { background: var(--primary-color); color: white; align-self: flex-end; border-bottom-right-radius: 2px; }
    .chat-input-area { background: white; }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const chatBtn = document.getElementById('chat-button');
        const chatWin = document.getElementById('chat-window');
        const closeChat = document.getElementById('close-chat');
        const sendBtn = document.getElementById('send-btn');
        const userInput = document.getElementById('user-input');
        const chatContent = document.getElementById('chat-content');

        // Bật/Tắt cửa sổ chat
        chatBtn.onclick = () => {
            chatWin.classList.remove('d-none');
            chatBtn.classList.add('d-none');
        };

        closeChat.onclick = () => {
            chatWin.classList.add('d-none');
            chatBtn.classList.remove('d-none');
        };

        // Hàm xử lý gửi tin nhắn
        async function handleChat() {
            const msg = userInput.value.trim();
            if(!msg) return;

            // Hiển thị tin nhắn người dùng
            chatContent.innerHTML += `<div class="user-msg">${msg}</div>`;
            userInput.value = '';
            chatContent.scrollTop = chatContent.scrollHeight;

            // Hiệu ứng "Đang trả lời..."
            const loadingId = 'loading-' + Date.now();
            chatContent.innerHTML += `<div class="bot-msg" id="${loadingId}">...</div>`;
            
            try {
                const res = await fetch('/api/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: msg })
                });
                const data = await res.json();
                
                // Xóa hiệu ứng loading và hiện câu trả lời thật
                document.getElementById(loadingId).remove();
                chatContent.innerHTML += `<div class="bot-msg">${data.text}</div>`;
            } catch (error) {
                document.getElementById(loadingId).innerText = "Trạm Trưởng đang bận chút, Vy đợi xíu nhé!";
            }
            chatContent.scrollTop = chatContent.scrollHeight;
        }

        sendBtn.onclick = handleChat;
        userInput.onkeypress = (e) => { if(e.key === 'Enter') handleChat(); };
    });
</script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const btnThongBao = document.getElementById('btnThongBao');
        const badgeThongBao = document.getElementById('badgeThongBao');

        if (btnThongBao) {
            // Dùng sự kiện 'shown.bs.dropdown' để đợi menu rớt xuống xong mới ẩn chấm đỏ
            btnThongBao.addEventListener('shown.bs.dropdown', function () {
                if (badgeThongBao) {
                    badgeThongBao.style.display = 'none';
                }
                // Gửi lệnh cập nhật Database ngầm
                fetch('/api/doc-thong-bao', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                }).catch(err => console.error('Lỗi thông báo:', err));
            });
        }
    });
</script>

