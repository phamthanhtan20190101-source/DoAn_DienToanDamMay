<%- include('partials/header') %>

<main class="container mt-5 pt-5">
    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h2 class="fw-bold text-success">
                <i class="bi bi-collection-play me-2"></i>Bài viết của tôi
            </h2>
            <p class="text-muted">Theo dõi và quản lý các tác phẩm Vy đã đóng góp cho Trạm Văn</p>
        </div>
        <div class="col-md-6 text-md-end">
            <a href="/gui-bai" class="btn btn-success rounded-pill px-4 shadow-sm">
                <i class="bi bi-pencil-square me-2"></i>Gửi bài mới
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="ps-4 py-3">Tác phẩm</th>
                            <th>Thể loại</th>
                            <th>Ngày đăng</th>
                            <th>Lượt xem</th>
                            <th>Trạng thái</th>
                            <th class="text-center pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (danhSachBai && danhSachBai.length > 0) { %>
                            <% danhSachBai.forEach(bai => { %>
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold text-dark"><%= bai.TieuDe %></div>
                                        <small class="text-muted text-truncate d-block" style="max-width: 250px;">
                                            <%= bai.TomTat %>
                                        </small>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border"><%= bai.TheLoai_id ? bai.TheLoai_id.TenTheLoai : 'Tự do' %></span>
                                    </td>
                                    <td>
                                        <small><%= new Date(bai.NgayDang).toLocaleDateString('vi-VN') %></small>
                                    </td>
                                    <td class="text-center">
                                        <i class="bi bi-eye text-primary me-1"></i><%= bai.LuotXem || 0 %>
                                    </td>
                                    <td>
                                        <% if (bai.TrangThai === 'DaDuyet') { %>
                                            <span class="badge rounded-pill bg-success-subtle text-success px-3">
                                                <i class="bi bi-check-circle me-1"></i>Đã duyệt
                                            </span>
                                        <% } else if (bai.TrangThai === 'ChoDuyet') { %>
                                            <span class="badge rounded-pill bg-warning-subtle text-warning px-3">
                                                <i class="bi bi-clock-history me-1"></i>Đang chờ
                                            </span>
                                        <% } else { %>
                                            <span class="badge rounded-pill bg-danger-subtle text-danger px-3">
                                                <i class="bi bi-exclamation-triangle me-1"></i>Từ chối
                                            </span>
                                        <% } %>
                                    </td>
                                    <td class="text-center pe-4">
                                        <div class="btn-group">
                                            <a href="/bai-van/<%= bai._id %>" class="btn btn-sm btn-outline-success">
                                                <i class="bi bi-box-arrow-up-right"></i>
                                            </a>
                                            </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <img src="https://cdn-icons-png.flaticon.com/512/7486/7486744.png" width="80" class="mb-3 opacity-50">
                                    <p class="text-muted">Vy chưa đăng bài nào hết trơn. Bắt đầu sáng tác ngay nhé!</p>
                                    <a href="/gui-bai" class="btn btn-sm btn-success">Gửi bài đầu tiên</a>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

<style>
    .bg-success-subtle { background-color: #e1f7e5 !important; }
    .bg-warning-subtle { background-color: #fff9e6 !important; }
    .bg-danger-subtle { background-color: #ffe6e6 !important; }
    .table-hover tbody tr:hover { background-color: #f8fdf9; }
</style>

<%- include('partials/footer') %>