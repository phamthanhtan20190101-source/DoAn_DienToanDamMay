<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard - Trạm Văn</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --primary-color: #435a24;
            --bg-color: #eef7e8;
            --sidebar-bg: #a8d08d;
            --white: #ffffff;
        }
        body { background: var(--bg-color); color: #333; font-family: 'Inter', sans-serif; display: flex; min-height: 100vh; margin: 0; }
        
        .sidebar { width: 280px; background: var(--sidebar-bg); height: 100vh; position: fixed; padding: 20px; box-shadow: 2px 0 10px rgba(0,0,0,0.05); }
        .sidebar-brand { color: var(--primary-color); text-decoration: none; font-size: 1.5rem; font-weight: bold; display: flex; align-items: center; gap: 10px; margin-bottom: 30px; }
        .sidebar a { color: var(--primary-color); text-decoration: none; padding: 12px 15px; display: block; border-radius: 8px; margin-bottom: 10px; transition: 0.3s; font-weight: 500; }
        .sidebar a:hover, .sidebar a.active { background: rgba(255,255,255,0.4); border-left: 4px solid var(--primary-color); }

        .main-content { margin-left: 280px; padding: 40px; width: calc(100% - 280px); }
        .stat-card { flex: 1; padding: 25px; border-radius: 15px; color: var(--white); position: relative; overflow: hidden; box-shadow: 0 8px 20px rgba(67, 90, 36, 0.15); transition: 0.3s; border: none; }
        .stat-card:hover { transform: translateY(-5px); }
        .stat-card i { position: absolute; right: -10px; bottom: -10px; font-size: 70px; opacity: 0.2; }
        .stat-card h3 { font-size: 14px; text-transform: uppercase; opacity: 0.9; margin: 0; }
        .stat-card p { font-size: 28px; font-weight: bold; margin: 10px 0 0 0; }
        
        .chart-box { margin-top: 35px; background: var(--white); padding: 25px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.03); }
        
        /* --- HIỆU ỨNG TRƯỢT MƯỢT MÀ --- */
    .sidebar, .main-content, header.top-bar, .page-container {
        transition: all 0.3s ease-in-out !important;
    }

    /* --- TRẠNG THÁI KHI SIDEBAR BỊ ẨN --- */
    body.sidebar-hidden .sidebar {
        transform: translateX(-280px); 
    }

    /* 1. Ép Main Content tràn đầy 100% màn hình để lấp khoảng trống bên phải */
    body.sidebar-hidden .main-content {
        margin-left: 0 !important;
        width: 100% !important; 
    }

    /* 2. Ép Top-bar tràn đầy 100% màn hình */
    body.sidebar-hidden header.top-bar {
        width: 100% !important; 
    }

    /* 3. Đảm bảo khung bài viết bên trong luôn tự động canh giữa */
    .page-container {
        margin: 0 auto !important; 
    }
    </style>
</head>
<body>
    <div class="sidebar d-flex flex-column" style="width: 280px; background: var(--sidebar-bg); height: 100vh; position: fixed; padding: 20px; box-shadow: 2px 0 10px rgba(0,0,0,0.05);">
    <a href="/admin/dashboard" class="sidebar-brand mb-4 text-decoration-none" style="color: var(--primary-color); font-weight: bold; font-size: 1.5rem; display: flex; align-items: center; gap: 10px;">
        <i class="bi bi-shield-check"></i> Trạm Văn Admin
    </a>

    <style>
        .admin-group-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: rgba(67, 90, 36, 0.6); display: block; font-weight: 700; margin-top: 1.5rem; margin-bottom: 0.5rem; padding-left: 5px;}
        .sidebar a { color: var(--primary-color); text-decoration: none; padding: 10px 15px; display: block; border-radius: 8px; font-weight: 500; transition: 0.3s; margin-bottom: 2px;}
        .sidebar a:hover, .sidebar a.active { background: rgba(255,255,255,0.4); border-left: 4px solid var(--primary-color); }
    </style>

    <div style="flex-grow: 1; overflow-y: auto;">
        <span class="admin-group-label" style="margin-top: 0;">Hệ thống</span>
        <a href="/admin/dashboard"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
        <a href="/admin/quan-ly-banner"><i class="bi bi-images me-2"></i> Quản lý Banner</a>
        <a href="/admin/duyet-bai"><i class="bi bi-check2-circle me-2"></i> Duyệt Bài Viết</a>

        <span class="admin-group-label">Nội dung</span>
        <a href="/admin/them-the-loai"><i class="bi bi-tags me-2"></i> Quản Lý Thể Loại</a>
        <a href="/admin/quan-ly-chu-de"><i class="bi bi-collection me-2"></i> Quản Lý Chủ Đề</a>
        <a href="/admin/quan-ly-bai-viet"><i class="bi bi-journal-text me-2"></i> Quản Lý Bài Viết</a>
        

        
        <span class="admin-group-label">Cộng đồng</span>
        <a href="/admin/quan-ly-nguoi-dung"><i class="bi bi-people me-2"></i> Quản Lý Người Dùng</a>
        <a href="/admin/quan-ly-binh-luan"><i class="bi bi-chat-square-text me-2"></i> Quản Lý Bình Luận</a>

        <span class="admin-group-label">Cấu hình</span>
        <a href="/admin/cai-dat-chung"><i class="bi bi-gear me-2"></i> Cài Đặt Chung</a>
    </div>

    <div class="mt-auto pt-3 border-top" style="border-color: rgba(67, 90, 36, 0.15) !important;">
        <a href="/" class="btn w-100 shadow-sm" style="background-color: var(--primary-color); color: white; border-radius: 10px; font-weight: 600; padding: 12px; display: flex; align-items: center; justify-content: center;">
            <i class="bi bi-house-door me-2"></i> Trở Về Trang Chủ
        </a>
    </div>
</div>

    <div class="main-content">
        <button id="sidebarToggle" class="toggle-btn">
            <i class="bi bi-list"></i> Menu
        </button>
        <h2 class="mb-4" style="color: var(--primary-color); font-weight: 700;">Bảng điều khiển hệ thống</h2>
        
        <div class="d-flex gap-3 mb-4">
            <div class="stat-card" style="background: linear-gradient(135deg, #435a24, #627D47);">
                <h3>Tổng bài viết</h3>
                <p><%= typeof stats !== 'undefined' ? stats.totalEssays : 0 %></p>
                <i class="bi bi-journal-text"></i>
            </div>
            <div class="stat-card" style="background: linear-gradient(135deg, #a8d08d, #435a24);">
                <h3>Thành viên</h3>
                <p><%= typeof stats !== 'undefined' ? stats.totalUsers : 0 %></p>
                <i class="bi bi-people"></i>
            </div>
            <div class="stat-card" style="background: linear-gradient(135deg, #627D47, #1a240f);">
                <h3>Đợi duyệt</h3>
                <p><%= typeof stats !== 'undefined' ? stats.pending : 0 %></p>
                <i class="bi bi-hourglass-split"></i>
            </div>
        </div>

        <div class="chart-box">
            <h4 style="color: var(--primary-color);">Tỉ lệ bài viết theo chuyên mục</h4>
            <canvas id="adminChart" height="100"></canvas>
        </div>
    </div>
    <script>
        const ctx = document.getElementById('adminChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['Nghị luận', 'Cảm nhận', 'Sáng tác', 'Khác'],
                datasets: [{
                    label: 'Số lượng',
                    data: [12, 19, 3, 5],
                    backgroundColor: '#435a24',
                    borderRadius: 8
                }]
            }
        });
    </script>
    <!-- Script để toggle sidebar -->
     <script>
        const sidebarToggle = document.getElementById('sidebarToggle');
        const body = document.body;

        // 1. Kiểm tra xem trước đó user có đang ẩn sidebar không
        if (localStorage.getItem('sidebar-state') === 'hidden') {
            body.classList.add('sidebar-hidden');
        }

        // 2. Xử lý khi bấm nút
        sidebarToggle.addEventListener('click', () => {
            // ĐÃ SỬA: Đổi 'sidebar-collapsed' thành 'sidebar-hidden' để khớp với CSS
            body.classList.toggle('sidebar-hidden');
            
            // 3. Đổi icon và lưu trạng thái vào bộ nhớ
            const icon = sidebarToggle.querySelector('i');
            if (body.classList.contains('sidebar-hidden')) {
                icon.className = 'bi bi-layout-sidebar-inset';
                localStorage.setItem('sidebar-state', 'hidden'); // Lưu lại là đang ẩn
            } else {
                icon.className = 'bi bi-list';
                localStorage.setItem('sidebar-state', 'visible'); // Lưu lại là đang hiện
            }
        });
    </script>
</body>
</html>