<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quản Lý Bình Luận - Trạm Văn Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root { --primary-color: #435a24; --bg-color: #eef7e8; --sidebar-bg: #a8d08d; }
        body { background: var(--bg-color); font-family: 'Inter', sans-serif; display: flex; margin: 0; min-height: 100vh; }
        .main-content { flex-grow: 1; margin-left: 280px; padding: 40px; }
        .table-card { background: white; border-radius: 15px; padding: 25px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); }
    </style>
</head>
<body>

    <div class="sidebar d-flex flex-column" style="width: 280px; background: var(--sidebar-bg); height: 100vh; position: fixed; padding: 20px; box-shadow: 2px 0 10px rgba(0,0,0,0.05); top: 0; left: 0;">
        <a href="/admin/dashboard" class="sidebar-brand mb-4 text-decoration-none" style="color: var(--primary-color); font-weight: bold; font-size: 1.5rem; display: flex; align-items: center; gap: 10px;">
            <i class="bi bi-shield-check"></i> Trạm Văn Admin
        </a>

        <style>
            .admin-group-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: rgba(67, 90, 36, 0.6); display: block; font-weight: 700; margin-top: 1.5rem; margin-bottom: 0.5rem; padding-left: 5px;}
            .sidebar a { color: var(--primary-color); text-decoration: none; padding: 10px 15px; display: block; border-radius: 8px; font-weight: 500; transition: 0.3s; margin-bottom: 2px;}
            .sidebar a:hover, .sidebar a.active { background: rgba(255,255,255,0.4); border-left: 4px solid var(--primary-color); }
        </style>

        <div style="flex-grow: 1; overflow-y: auto;">
            <span class="admin-group-label" style="margin-top: 0;">Hệ thống</span>
            <a href="/admin/dashboard"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
            <a href="#"><i class="bi bi-images me-2"></i> Quản lý Banner</a>
            <a href="/admin/duyet-bai"><i class="bi bi-check2-circle me-2"></i> Duyệt Bài Viết</a>

            <span class="admin-group-label">Nội dung</span>
            <a href="/admin/them-the-loai"><i class="bi bi-tags me-2"></i> Quản Lý Thể Loại</a>
            <a href="/admin/quan-ly-bai-viet"><i class="bi bi-journal-text me-2"></i> Quản Lý Bài Viết</a>

            <span class="admin-group-label">Cộng đồng</span>
            <a href="#"><i class="bi bi-people me-2"></i> Quản Lý Người Dùng</a>
            <a href="/admin/quan-ly-binh-luan" class="active"><i class="bi bi-chat-square-text me-2"></i> Quản Lý Bình Luận</a>

            <span class="admin-group-label">Cấu hình</span>
            <a href="#"><i class="bi bi-gear me-2"></i> Cài Đặt Chung</a>
        </div>

        <div class="mt-auto pt-3 border-top" style="border-color: rgba(67, 90, 36, 0.15) !important;">
            <a href="/" class="btn w-100 shadow-sm" style="background-color: var(--primary-color); color: white; border-radius: 10px; font-weight: 600; padding: 12px; display: flex; align-items: center; justify-content: center;">
                <i class="bi bi-house-door me-2"></i> Trở Về Trang Chủ
            </a>
        </div>
    </div>

    <div class="main-content">
        <h2 class="mb-4" style="color: var(--primary-color); font-weight: 700;">Quản Lý Bình Luận</h2>

        <div class="table-card">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 15%;">Người bình luận</th>
                        <th style="width: 40%;">Nội dung</th>
                        <th style="width: 20%;">Bài viết</th>
                        <th style="width: 15%;">Thời gian</th>
                        <th style="width: 10%;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof danhSachBinhLuan !== 'undefined' && danhSachBinhLuan.length > 0) { %>
                        <% danhSachBinhLuan.forEach(bl => { %>
                            <tr>
                                <td>
                                    <strong><%= bl.TaiKhoan_id ? bl.TaiKhoan_id.HoTen : 'Vô danh' %></strong>
                                </td>
                                <td>
                                    <div style="max-height: 80px; overflow-y: auto; font-size: 0.95rem; color: #444;">
                                        <%= bl.NoiDung %>
                                    </div>
                                </td>
                                <td>
                                    <% if (bl.BaiVan_id) { %>
                                        <a href="/bai-van/<%= bl.BaiVan_id._id %>" target="_blank" class="text-decoration-none" style="color: var(--primary-color); font-weight: 500; font-size: 0.9rem;">
                                            <i class="bi bi-link-45deg"></i> <%= bl.BaiVan_id.TieuDe %>
                                        </a>
                                    <% } else { %>
                                        <span class="text-danger small"><i class="bi bi-exclamation-circle"></i> Bài viết đã bị xóa</span>
                                    <% } %>
                                </td>
                                <td class="text-muted small">
                                    <%= new Date(bl.NgayBinhLuan).toLocaleDateString('vi-VN') %><br>
                                    <%= new Date(bl.NgayBinhLuan).toLocaleTimeString('vi-VN') %>
                                </td>
                                <td>
                                    <a href="/admin/xoa-binh-luan/<%= bl._id %>" class="btn btn-sm btn-outline-danger" title="Xóa bình luận" onclick="return confirm('Bạn có chắc chắn muốn xóa bình luận này không?');">
                                        <i class="bi bi-trash"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-chat-left-dots fs-1 d-block mb-3"></i>
                                Chưa có bình luận nào trên hệ thống.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>