<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quản lý Thể Loại - Trạm Văn</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root { --primary-color: #435a24; --bg-color: #eef7e8; --sidebar-bg: #a8d08d; --white: #ffffff; }
        body { background: var(--bg-color); color: #333; font-family: 'Inter', sans-serif; display: flex; min-height: 100vh; margin: 0; }
        .sidebar { width: 280px; background: var(--sidebar-bg); height: 100vh; position: fixed; padding: 20px; box-shadow: 2px 0 10px rgba(0,0,0,0.05); }
        .sidebar a { color: var(--primary-color); text-decoration: none; padding: 12px 15px; display: block; border-radius: 8px; margin-bottom: 10px; font-weight: 500; transition: 0.3s; }
        .sidebar a:hover, .sidebar a.active { background: rgba(255,255,255,0.4); border-left: 4px solid var(--primary-color); }
        .main-content { margin-left: 280px; padding: 40px; width: calc(100% - 280px); }
        .upload-card { background: var(--white); border-radius: 20px; padding: 2.5rem; box-shadow: 0 10px 40px rgba(67, 90, 36, 0.05); margin-bottom: 30px; }
        /* --- HIỆU ỨNG ẨN/HIỆN SIDEBAR --- */
        .sidebar, .main-content {
            transition: all 0.3s ease-in-out !important;
        }

        body.sidebar-hidden .sidebar {
            transform: translateX(-280px); /* Đẩy sidebar ra ngoài */
        }

        body.sidebar-hidden .main-content {
            margin-left: 0 !important;
            width: 100% !important; 
        }

        /* Nút Toggle */
        .toggle-btn {
            background: var(--primary-color);
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 8px;
            cursor: pointer;
            margin-bottom: 20px;
            transition: 0.3s;
            font-weight: bold;
        }
        .toggle-btn:hover { background: var(--accent-color, #627D47); }
    
    </style>
</head>
<body>
    <div class="sidebar d-flex flex-column" style="width: 280px; background: var(--sidebar-bg); height: 100vh; position: fixed; padding: 20px; box-shadow: 2px 0 10px rgba(0,0,0,0.05);">
    <a href="/admin/dashboard" class="sidebar-brand mb-4 text-decoration-none" style="color: var(--primary-color); font-weight: bold; font-size: 1.5rem; display: flex; align-items: center; gap: 10px;">
        <i class="bi bi-shield-check"></i> Trạm Văn Admin
    </a>

    <style>
        .admin-group-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: rgba(67, 90, 36, 0.6); display: block; font-weight: 700; margin-top: 1.5rem; margin-bottom: 0.5rem; padding-left: 5px;}
        .sidebar a { color: var(--primary-color); text-decoration: none; padding: 10px 15px; display: block; border-radius: 8px; font-weight: 500; transition: 0.3s; margin-bottom: 2px;}
        .sidebar a:hover, .sidebar a.active { background: rgba(255,255,255,0.4); border-left: 4px solid var(--primary-color); }
    </style>

    <div style="flex-grow: 1; overflow-y: auto;">
        <span class="admin-group-label" style="margin-top: 0;">Hệ thống</span>
        <a href="/admin/dashboard"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
        <a href="#"><i class="bi bi-images me-2"></i> Quản lý Banner</a>
        <a href="/admin/duyet-bai"><i class="bi bi-check2-circle me-2"></i> Duyệt Bài Viết</a>

        <span class="admin-group-label">Nội dung</span>
        <a href="/admin/them-the-loai"><i class="bi bi-tags me-2"></i> Quản Lý Thể Loại</a>
        <a href="/admin/quan-ly-bai-viet"><i class="bi bi-journal-text me-2"></i> Quản Lý Bài Viết</a>

        <span class="admin-group-label">Cộng đồng</span>
        <a href="/admin/quan-ly-nguoi-dung"><i class="bi bi-people me-2"></i> Quản Lý Người Dùng</a>
        <a href="/admin/quan-ly-binh-luan"><i class="bi bi-chat-square-text me-2"></i> Quản Lý Bình Luận</a>

        <span class="admin-group-label">Cấu hình</span>
        <a href="#"><i class="bi bi-gear me-2"></i> Cài Đặt Chung</a>
    </div>

    <div class="mt-auto pt-3 border-top" style="border-color: rgba(67, 90, 36, 0.15) !important;">
        <a href="/" class="btn w-100 shadow-sm" style="background-color: var(--primary-color); color: white; border-radius: 10px; font-weight: 600; padding: 12px; display: flex; align-items: center; justify-content: center;">
            <i class="bi bi-house-door me-2"></i> Trở Về Trang Chủ
        </a>
    </div>
</div>

    <div class="main-content">
        <button id="sidebarToggle" class="toggle-btn">
            <i class="bi bi-list"></i> Menu
        </button>
        <div class="upload-card">
            <h3 style="color: var(--primary-color); font-weight: 700;">Thêm chuyên mục mới</h3>
            <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
            <form action="/admin/them-the-loai" method="POST" class="mt-3">
                <div class="mb-3">
                    <label class="form-label">Tên thể loại</label>
                    <input type="text" name="TenTheLoai" class="form-control" style="border-radius: 10px;" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Mô tả</label>
                    <textarea name="MoTa" class="form-control" style="border-radius: 10px;" rows="2"></textarea>
                </div>
                <button type="submit" class="btn btn-success w-100" style="background-color: var(--primary-color); border: none; border-radius: 10px; padding: 12px;">
                    <i class="bi bi-plus-circle me-2"></i> Lưu chuyên mục
                </button>
            </form>
        </div>

        <div class="upload-card">
            <h4 style="color: var(--primary-color); font-weight: 700;">Danh sách hiện có</h4>
            <table class="table table-hover mt-3">
                <thead><tr><th>Tên thể loại</th><th>Mô tả</th><th>Hành động</th></tr></thead>
                <tbody>
                    <% danhSachTheLoai.forEach(tl => { %>
                        <tr>
                            <td><span class="badge bg-success"><%= tl.TenTheLoai %></span></td>
                            <td class="text-muted"><%= tl.MoTa %></td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a href="/admin/sua-the-loai/<%= tl._id %>" class="btn btn-sm btn-outline-primary" title="Sửa thể loại">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                            
                                    <a href="/admin/xoa-the-loai/<%= tl._id %>" class="btn btn-sm btn-outline-danger" title="Xóa thể loại"
                                        onclick="return confirm('Bạn có chắc chắn muốn xóa thể loại này không?');">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
    <!-- --- HIỆU ỨNG ẨN/HIỆN SIDEBAR --- -->
     <script>
        document.addEventListener('DOMContentLoaded', function() {
            const sidebarToggle = document.getElementById('sidebarToggle');
            const body = document.body;

            // Kiểm tra trạng thái đã lưu
            if (localStorage.getItem('sidebar-state') === 'hidden') {
                body.classList.add('sidebar-hidden');
                sidebarToggle.querySelector('i').className = 'bi bi-layout-sidebar-inset';
            }

            // Xử lý khi bấm nút
            sidebarToggle.addEventListener('click', () => {
                body.classList.toggle('sidebar-hidden');
                
                const icon = sidebarToggle.querySelector('i');
                if (body.classList.contains('sidebar-hidden')) {
                    icon.className = 'bi bi-layout-sidebar-inset';
                    localStorage.setItem('sidebar-state', 'hidden');
                } else {
                    icon.className = 'bi bi-list';
                    localStorage.setItem('sidebar-state', 'visible');
                }
            });
        });
    </script>
</body>
</html>