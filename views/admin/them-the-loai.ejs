<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quản lý Thể Loại - Trạm Văn</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root { --primary-color: #435a24; --bg-color: #eef7e8; --sidebar-bg: #a8d08d; --white: #ffffff; }
        body { background: var(--bg-color); color: #333; font-family: 'Inter', sans-serif; display: flex; min-height: 100vh; margin: 0; }
        .sidebar { width: 280px; background: var(--sidebar-bg); height: 100vh; position: fixed; padding: 20px; box-shadow: 2px 0 10px rgba(0,0,0,0.05); }
        .sidebar a { color: var(--primary-color); text-decoration: none; padding: 12px 15px; display: block; border-radius: 8px; margin-bottom: 10px; font-weight: 500; transition: 0.3s; }
        .sidebar a:hover, .sidebar a.active { background: rgba(255,255,255,0.4); border-left: 4px solid var(--primary-color); }
        .main-content { margin-left: 280px; padding: 40px; width: calc(100% - 280px); }
        .upload-card { background: var(--white); border-radius: 20px; padding: 2.5rem; box-shadow: 0 10px 40px rgba(67, 90, 36, 0.05); margin-bottom: 30px; }
    </style>
</head>
<body>
    <div class="sidebar">
        <h4 class="mb-4" style="color: var(--primary-color); font-weight: bold;"><i class="bi bi-shield-check"></i> Trạm Văn Admin</h4>
        <a href="/admin/dashboard"><i class="bi bi-speedometer2 me-2"></i> Tổng quan</a>
        <a href="/admin/them-the-loai" class="active"><i class="bi bi-tags me-2"></i> Quản lý thể loại</a>
        <a href="/admin/duyet-bai"><i class="bi bi-check2-circle me-2"></i> Duyệt bài viết</a>
        <hr style="opacity: 0.1;">
        <a href="/"><i class="bi bi-house me-2"></i> Về trang chủ</a>
        <a href="/dang-xuat" class="text-danger"><i class="bi bi-box-arrow-right me-2"></i> Đăng xuất</a>
    </div>

    <div class="main-content">
        <div class="upload-card">
            <h3 style="color: var(--primary-color); font-weight: 700;">Thêm chuyên mục mới</h3>
            <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
            <form action="/admin/them-the-loai" method="POST" class="mt-3">
                <div class="mb-3">
                    <label class="form-label">Tên thể loại</label>
                    <input type="text" name="TenTheLoai" class="form-control" style="border-radius: 10px;" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Mô tả</label>
                    <textarea name="MoTa" class="form-control" style="border-radius: 10px;" rows="2"></textarea>
                </div>
                <button type="submit" class="btn btn-success w-100" style="background-color: var(--primary-color); border: none; border-radius: 10px; padding: 12px;">
                    <i class="bi bi-plus-circle me-2"></i> Lưu chuyên mục
                </button>
            </form>
        </div>

        <div class="upload-card">
            <h4 style="color: var(--primary-color); font-weight: 700;">Danh sách hiện có</h4>
            <table class="table table-hover mt-3">
                <thead><tr><th>Tên thể loại</th><th>Mô tả</th><th>Hành động</th></tr></thead>
                <tbody>
                    <% danhSachTheLoai.forEach(tl => { %>
                        <tr>
                            <td><span class="badge bg-success"><%= tl.TenTheLoai %></span></td>
                            <td class="text-muted"><%= tl.MoTa %></td>
                            <td><a href="/admin/xoa-the-loai/<%= tl._id %>" class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa?')">Xóa</a></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>