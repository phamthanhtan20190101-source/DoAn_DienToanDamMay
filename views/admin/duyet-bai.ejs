<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Duyệt Bài - Trạm Văn Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root { --primary-color: #435a24; --bg-color: #eef7e8; --sidebar-bg: #a8d08d; --white: #ffffff; }
        body { background: var(--bg-color); font-family: 'Inter', sans-serif; display: flex; min-height: 100vh; margin: 0; }
        
        .sidebar { width: 280px; background: var(--sidebar-bg); height: 100vh; position: fixed; padding: 20px; box-shadow: 2px 0 10px rgba(0,0,0,0.05); }
        .sidebar-brand { color: var(--primary-color); text-decoration: none; font-size: 1.5rem; font-weight: bold; display: flex; align-items: center; gap: 10px; margin-bottom: 30px; }
        .sidebar a { color: var(--primary-color); text-decoration: none; padding: 12px 15px; display: block; border-radius: 8px; margin-bottom: 10px; font-weight: 500; }
        .sidebar a:hover, .sidebar a.active { background: rgba(255,255,255,0.4); border-left: 4px solid var(--primary-color); }
        
        .main-content { margin-left: 280px; padding: 40px; width: calc(100% - 280px); }
        .table-box { background: var(--white); padding: 25px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.03); }
    </style>
</head>
<body>
    <div class="sidebar">
        <a href="/admin/dashboard" class="sidebar-brand">
            <i class="bi bi-shield-check"></i> Trạm Văn Admin
        </a>
        <a href="/admin/dashboard"><i class="bi bi-speedometer2 me-2"></i> Tổng quan</a>
        <a href="/admin/duyet-bai" class="active"><i class="bi bi-check2-circle me-2"></i> Duyệt bài viết</a>
        <a href="/admin/them-the-loai"><i class="bi bi-tags me-2"></i> Quản lý thể loại</a>
        <hr style="opacity: 0.1;">
        <a href="/"><i class="bi bi-house me-2"></i> Về trang chủ</a>
    </div>

    <div class="main-content">
        <h2 style="color: var(--primary-color); margin-bottom: 20px; font-weight: bold;">Danh sách bài chờ duyệt</h2>
        
        <div class="table-box">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Tiêu đề tác phẩm</th>
                        <th>Tác giả</th>
                        <th>Ngày gửi</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof danhSachChoDuyet === 'undefined' || danhSachChoDuyet.length === 0) { %>
                        <tr><td colspan="4" class="text-center text-muted py-4">Không có bài viết nào đang chờ duyệt.</td></tr>
                    <% } else { %>
                        <% danhSachChoDuyet.forEach(bai => { %>
                            <tr>
                                <td><strong><%= bai.TieuDe %></strong></td>
                                <td><%= bai.TacGia_id ? bai.TacGia_id.HoTen : 'Vô danh' %></td>
                                <td><%= new Date(bai.NgayDang).toLocaleDateString('vi-VN') %></td>
                                <td>
                                    <form action="/admin/xu-ly-bai/<%= bai._id %>" method="POST" class="d-flex gap-2 mb-0">
                                        <button type="submit" name="action" value="chap-nhan" class="btn btn-sm" style="background-color: var(--primary-color); color: white;"><i class="bi bi-check-lg"></i> Duyệt</button>
                                        <button type="submit" name="action" value="tu-choi" class="btn btn-sm btn-danger"><i class="bi bi-x-lg"></i> Từ chối</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>