<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Sửa Bài Viết - Trạm Văn</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root { --primary-color: #435a24; --bg-color: #eef7e8; --white: #ffffff; }
        body { background: var(--bg-color); font-family: 'Inter', sans-serif; }
        .main-content { padding: 40px; max-width: 800px; margin: 0 auto; }
        .upload-card { background: var(--white); border-radius: 20px; padding: 2.5rem; box-shadow: 0 10px 40px rgba(67, 90, 36, 0.05); }
    </style>
</head>
<body>
    <div class="main-content">
        <div class="d-flex align-items-center mb-4">
            <a href="/admin/quan-ly-bai-viet" class="btn btn-outline-secondary me-3 rounded-circle" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;"><i class="bi bi-arrow-left"></i></a>
            <h2 class="mb-0" style="color: var(--primary-color); font-weight: 700;">Chỉnh sửa Bài viết</h2>
        </div>
        
        <div class="upload-card">
            <form action="/admin/sua-bai/<%= bai._id %>" method="POST">
                <div class="mb-3">
                    <label class="form-label fw-bold">Tiêu đề bài viết</label>
                    <input type="text" name="TieuDe" class="form-control" value="<%= bai.TieuDe %>" style="border-radius: 10px;" required>
                </div>
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Thể loại</label>
                        <select name="TheLoai_id" class="form-select" style="border-radius: 10px;">
                            <% danhSachTheLoai.forEach(tl => { %>
                                <option value="<%= tl._id %>" <%= bai.TheLoai_id && bai.TheLoai_id.toString() === tl._id.toString() ? 'selected' : '' %>><%= tl.TenTheLoai %></option>
                            <% }) %>
                        </select>
                    </div>
                    
                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold text-danger">Gán vào Chủ Đề (Module Cuộn Ngang)</label>
                        <select name="ChuDe_id" class="form-select" style="border-radius: 10px; border-color: #ffc107;">
                            <option value="">-- Không gán chủ đề --</option>
                            <% danhSachChuDe.forEach(cd => { %>
                                <option value="<%= cd._id %>" <%= bai.ChuDe_id && bai.ChuDe_id.toString() === cd._id.toString() ? 'selected' : '' %>><%= cd.TenChuDe %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Trạng thái</label>
                    <select name="TrangThai" class="form-select" style="border-radius: 10px;">
                        <option value="DaDuyet" <%= bai.TrangThai === 'DaDuyet' ? 'selected' : '' %>>Đã duyệt (Hiển thị)</option>
                        <option value="ChoDuyet" <%= bai.TrangThai === 'ChoDuyet' ? 'selected' : '' %>>Chờ duyệt (Ẩn)</option>
                    </select>
                </div>
                
                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-success w-50" style="background-color: var(--primary-color); border: none; border-radius: 10px; padding: 12px;"><i class="bi bi-save me-2"></i> Lưu Thay Đổi</button>
                    <a href="/admin/quan-ly-bai-viet" class="btn btn-light w-50" style="border-radius: 10px; padding: 12px; font-weight: 500;">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>