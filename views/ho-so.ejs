<%- include('partials/header') %>

<div class="page-container">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold" style="font-family: 'Judson', serif; color: var(--primary-color);">
                <i class="bi bi-person-vcard me-2"></i>Hồ Sơ Của Vy
            </h2>
            <p class="text-muted">Xem và quản lý thông tin tài khoản của bạn.</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 p-4 mx-auto" style="max-width: 600px; background-color: white;">
        
        <div class="text-center mb-4 pb-3 border-bottom">
            <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3"
                 style="width: 120px; height: 120px; background-color: #eef7e8; color: var(--primary-color); font-size: 4rem;">
                <i class="bi bi-person-fill"></i>
            </div>
            <h3 class="fw-bold mb-2" style="font-family: 'Judson', serif;"><%= user.HoTen %></h3>
            
            <% if (user.QuyenHan === 'admin') { %>
                <span class="badge rounded-pill bg-danger px-3 py-2"><i class="bi bi-shield-lock me-1"></i> Quản Trị Viên</span>
            <% } else { %>
                <span class="badge rounded-pill bg-success px-3 py-2"><i class="bi bi-pencil-square me-1"></i> Tác Giả Trạm Văn</span>
            <% } %>
        </div>

        <ul class="list-group list-group-flush fs-5">
            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                <span class="text-muted fw-medium"><i class="bi bi-person-badge me-2"></i>Tên đăng nhập:</span>
                <strong class="text-dark"><%= user.TenDangNhap %></strong>
            </li>
            
            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                <span class="text-muted fw-medium"><i class="bi bi-activity me-2"></i>Trạng thái tài khoản:</span>
                <% if (user.KichHoat === 1) { %>
                    <span class="text-success fw-bold"><i class="bi bi-check-circle-fill me-1"></i> Đang hoạt động</span>
                <% } else { %>
                    <span class="text-danger fw-bold"><i class="bi bi-lock-fill me-1"></i> Bị khóa</span>
                <% } %>
            </li>
        </ul>

        <div class="mt-5 text-center">
            <a href="/" class="btn btn-auth-outline rounded-pill px-4 py-2 me-2">
                <i class="bi bi-house me-1"></i> Về trang chủ
            </a>
            <button type="button" class="btn btn-auth-solid rounded-pill px-4 py-2" data-bs-toggle="modal"
                data-bs-target="#modalDoiMatKhau">
                <i class="bi bi-key me-1"></i> Đổi mật khẩu
            </button>
        </div>
    </div>

    <div class="modal fade" id="modalDoiMatKhau" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold" style="color: var(--primary-color);"><i class="bi bi-shield-lock me-2"></i>Đổi Mật Khẩu</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div id="thongBaoDoiMK" class="alert d-none rounded-3" role="alert"></div>
                
                <form id="formDoiMatKhau">
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">MẬT KHẨU HIỆN TẠI</label>
                        <input type="password" class="form-control form-control-lg bg-light" id="matKhauCu" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">MẬT KHẨU MỚI</label>
                        <input type="password" class="form-control form-control-lg bg-light" id="matKhauMoi" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold">XÁC NHẬN MẬT KHẨU MỚI</label>
                        <input type="password" class="form-control form-control-lg bg-light" id="xacNhanMK" required>
                    </div>
                    <button type="submit" class="btn btn-auth-solid w-100 rounded-pill py-2 fw-bold" id="btnLuuMatKhau">
                        Cập nhật mật khẩu
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('formDoiMatKhau').addEventListener('submit', async function(e) {
        e.preventDefault(); // Chặn việc tải lại trang
        
        const matKhauCu = document.getElementById('matKhauCu').value;
        const matKhauMoi = document.getElementById('matKhauMoi').value;
        const xacNhanMK = document.getElementById('xacNhanMK').value;
        const thongBao = document.getElementById('thongBaoDoiMK');
        const btnLuu = document.getElementById('btnLuuMatKhau');

        // Kiểm tra khớp mật khẩu
        if (matKhauMoi !== xacNhanMK) {
            thongBao.className = 'alert alert-danger rounded-3';
            thongBao.innerText = 'Mật khẩu xác nhận không khớp!';
            thongBao.classList.remove('d-none');
            return;
        }

        // Vô hiệu hóa nút bấm trong lúc chờ xử lý
        btnLuu.disabled = true;
        btnLuu.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...';

        try {
            const res = await fetch('/api/doi-mat-khau', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ matKhauCu, matKhauMoi })
            });
            const data = await res.json();

            thongBao.classList.remove('d-none');
            if (data.success) {
                thongBao.className = 'alert alert-success rounded-3';
                thongBao.innerHTML = '<i class="bi bi-check-circle-fill me-2"></i>' + data.msg;
                document.getElementById('formDoiMatKhau').reset(); // Xóa trắng form
            } else {
                thongBao.className = 'alert alert-danger rounded-3';
                thongBao.innerText = data.msg;
            }
        } catch (err) {
            thongBao.className = 'alert alert-danger rounded-3';
            thongBao.innerText = 'Lỗi kết nối đến máy chủ!';
        } finally {
            // Phục hồi lại nút bấm
            btnLuu.disabled = false;
            btnLuu.innerText = 'Cập nhật mật khẩu';
        }
    });
</script>

</div>

<%- include('partials/footer') %>