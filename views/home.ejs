                                                                                    <a href="/bai-van/<%= bai._id %>"
                                                                                        class="text-decoration-none fw-bold"
                                                                                        style="color: var(--primary-color);">Đọc
                                                                                        tiếp <i
                                                                                            class="bi bi-arrow-right ms-1"></i></a>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                        <% }) %>
