                                                                                        <% } %>
                                                            </div>
                                                        </div>
                                                        <hr class="mb-5 opacity-10">
                                                        <h4 class="mb-4 text-muted"><i
                                                                class="bi bi-heart-fill text-danger me-2"></i>Danh sách
                                                            yêu
                                                            thích</h4>
                                                        <% } %>

                                                            <div class="row g-4">
                                                                <% if (typeof danhSachBai !=='undefined' &&
                                                                    danhSachBai.length>
                                                                    0) { %>
                                                                    <% danhSachBai.forEach(bai=> { %>
                                                                        <div class="col-md-4 mb-4">
                                                                            <div class="essay-card bg-white rounded-4 p-4 d-flex flex-column h-100 position-relative transition-hover"
                                                                                style="box-shadow: 0 4px 15px rgba(67, 90, 36, 0.05); border: 1px solid rgba(67, 90, 36, 0.08);">
