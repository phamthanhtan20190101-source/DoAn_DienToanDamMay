                                                                                            tiếp
                                                                                            <i
                                                                                                class="bi bi-arrow-right"></i></a>
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                            <% } %>
                                                                                <% }) %>
                                                                                    <% } else { %>
                                                                                        <div
                                                                                            class="col-12 text-center text-muted py-3">
                                                                                            Bạn chưa xem tác phẩm nào
                                                                                            gần đây.
