<%- include('partials/header') %>

<div class="content-wrapper p-4 d-flex align-items-center justify-content-center" style="min-height: calc(100vh - 100px);">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden" style="max-width: 500px; width: 100%;">
        <div class="card-header text-center py-4 border-0" style="background-color: var(--bg-color);">
            <i class="bi bi-feather fs-1 text-success mb-2"></i>
            <h3 class="fw-bold mb-0" style="color: var(--primary-color); font-family: 'Judson', serif;">Gia nhập Trạm Văn</h3>
            <p class="text-muted small mt-1 mb-0">Tạo tài khoản để cùng chia sẻ những áng văn hay</p>
        </div>
        
        <div class="card-body p-4 p-md-5 bg-white">
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-danger rounded-3 small py-2 text-center">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i> <%= error %>
                </div>
            <% } %>

            <form action="/dang-ky" method="POST">
                <div class="mb-3">
                    <label class="form-label fw-bold small text-muted">Họ và tên của bạn</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-person text-muted"></i></span>
                        <input type="text" name="HoTen" class="form-control bg-light border-start-0" placeholder="VD: Vũ Thị Yến Vy" required>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold small text-muted">Tên đăng nhập</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-at text-muted"></i></span>
                        <input type="text" name="TenDangNhap" class="form-control bg-light border-start-0" placeholder="Viết liền không dấu" required>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold small text-muted">Mật khẩu</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock text-muted"></i></span>
                        <input type="password" name="MatKhau" class="form-control bg-light border-start-0" placeholder="Tối thiểu 6 ký tự" required>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold small text-muted">Xác nhận lại mật khẩu</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-shield-lock text-muted"></i></span>
                        <input type="password" name="XacNhanMatKhau" class="form-control bg-light border-start-0" placeholder="Nhập lại mật khẩu ở trên" required>
                    </div>
                </div>

                <button type="submit" class="btn btn-success w-100 rounded-pill py-2 fw-bold shadow-sm mb-3">
                    Đăng Ký Tài Khoản
                </button>

                <p class="text-center text-muted small mb-0">
                    Đã có tài khoản? <a href="/dang-nhap" class="text-success fw-bold text-decoration-none">Đăng nhập ngay</a>
                </p>
            </form>
        </div>
    </div>
</div>

<style>
    /* Làm đẹp cho các ô nhập liệu */
    .form-control:focus {
        box-shadow: none;
        border-color: #dee2e6;
        background-color: white !important;
    }
    .input-group-text, .form-control { border-radius: 10px; }
</style>

<%- include('partials/footer') %>